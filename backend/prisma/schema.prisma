generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Raw ingredients — from CSV (ID is numeric string from Shopify)
model Ingredient {
  id            String         @id
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  srIngredients SRIngredient[]
}

// Sub-recipes — from CSV
model SubRecipe {
  id               String          @id
  name             String
  station          String?
  day              String?
  priority         Int?
  prepInstructions String?         @db.Text
  backendUrl       String?
  baseWeight       Float?
  baseUnit         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ingredients      SRIngredient[]
  mealLinks        MealSubRecipe[]
}

// Ingredients within a sub-recipe
model SRIngredient {
  id           String     @id @default(uuid())
  subRecipeId  String
  ingredientId String
  weight       Float?
  unit         String?
  trimPct      Float?
  subRecipe    SubRecipe  @relation(fields: [subRecipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([subRecipeId, ingredientId])
}

// Meals — from CSV
model Meal {
  id         String              @id
  name       String
  category   String?
  price      String?
  backendUrl String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  subRecipes MealSubRecipe[]
  planItems  ProductionPlanItem[]
}

// Which sub-recipes go into a meal, with per-portion quantities
model MealSubRecipe {
  id          String    @id @default(uuid())
  mealId      String
  subRecipeId String
  srName      String?
  perPortion  Float?
  unit        String?
  meal        Meal      @relation(fields: [mealId], references: [id], onDelete: Cascade)
  subRecipe   SubRecipe @relation(fields: [subRecipeId], references: [id])

  @@unique([mealId, subRecipeId])
}

// Production Plans — saved weekly schedules
model ProductionPlan {
  id             String               @id @default(uuid())
  name           String
  weekLabel      String?
  productionDate DateTime?
  status         String               @default("draft")
  notes          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  items          ProductionPlanItem[]
}

// Each meal + quantity in a production plan
model ProductionPlanItem {
  id       String         @id @default(uuid())
  planId   String
  mealId   String
  quantity Int            @default(0)
  plan     ProductionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  meal     Meal           @relation(fields: [mealId], references: [id])

  @@unique([planId, mealId])
}
